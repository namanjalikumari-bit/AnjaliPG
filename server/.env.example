# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3002

# ---- Database (MongoDB Atlas) ----
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/anjali_pg?retryWrites=true&w=majority

# ---- Auth ----
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=30d

# ---- Cloudinary (image storage) ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- Email (Nodemailer / SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_NAME=Anjali PG
FROM_EMAIL=your_email@gmail.com
ADMIN_EMAIL=owner@anjalipg.com

# ---- Optional AI (complaint categorization). Leave blank to disable. ----
AI_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001

# ---- Default admin (used by seed) ----
ADMIN_NAME=Anjali Owner
ADMIN_LOGIN_EMAIL=admin@anjalipg.com
ADMIN_LOGIN_PASSWORD=admin123
